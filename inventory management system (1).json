    {
      "parameters": {
        "jsCode": "// Get all inputs from previous nodes\nconst inputs = $input.all();\n\n// Ensure both inputs are present\nif (inputs.length < 2) {\n  throw new Error(\"Both Ordered Shipment and Current Stock nodes must be connected to this Code node.\");\n}\n\n// Extract JSON arrays from both sheets\nconst orderedItems = inputs[0].json.items || [inputs[0].json];\nconst stockItems = inputs[1].json.items || [inputs[1].json];\n\n// Debugging\nconsole.log(`Ordered Items: ${orderedItems.length}`);\nconsole.log(`Stock Items: ${stockItems.length}`);\n\n// Helper to generate shipment IDs\nfunction generateShipmentID() {\n  const now = new Date();\n  const rand = Math.floor(Math.random() * 1000);\n  return `SHIP-${now.getFullYear()}${String(now.getMonth()+1).padStart(2,'0')}${String(now.getDate()).padStart(2,'0')}-${rand}`;\n}\n\n// Create a map using barcode as key\nconst mergedMap = new Map();\n\n// Insert ordered items into the map\nfor (const item of orderedItems) {\n  const barcode = String(item.BarCode || item.Barcode || '').trim();\n  if (!barcode) continue;\n\n  mergedMap.set(barcode, {\n    ...item,\n    BarCode: barcode,\n    Quantity: parseInt(item.Quantity || 0),\n    \"Shipment Tracking\": item[\"Shipment Tracking\"] || '',\n  });\n}\n\n// Merge current stock items\nfor (const stockItem of stockItems) {\n  const barcode = String(stockItem.BarCode || stockItem.Barcode || '').trim();\n  console.log(\"BARCODE\", barcode)\n  if (!barcode) continue;\n\n  const quantity = parseInt(stockItem.Quantity || 0);\n  const itemName = stockItem[\"Item name\"] || stockItem.ItemName || \"\";\n\n  console.log(\"MergedMap\", mergedMap)\n  if (mergedMap.has(barcode)) {\n    const existing = mergedMap.get(barcode);\n\n    // Update quantity\n    existing.Quantity = quantity;\n\n    // Generate Shipment Tracking if quantity > 0 OR tracking is missing/empty\n    if (quantity > 0 || !existing[\"Shipment Tracking\"]?.trim()) {\n      const newID = generateShipmentID();\n      \n      console.log(`Generated Shipment ID ${newID} for barcode ${barcode}`);\n      existing[\"Shipment Tracking\"] = newID;\n    }\n    mergedMap.set(barcode, existing);\n  } else {\n    // New item from stock — add it\n    const newTrackingID = generateShipmentID()\n    mergedMap.set(barcode, {\n      \"Item name\": itemName,\n      BarCode: barcode,\n      Quantity: quantity,\n      \"Shipment Tracking\": newTrackingID,\n    });\n  }\n}\n\n// Prepare final merged output\nconst mergedArray = Array.from(mergedMap.values()).map((item, index) => ({\n  ...item,\n  row_number: index + 1\n}));\n\nconsole.log(`Merged Total Items: ${mergedArray.length}`);\nconsole.log(\"Final Merged Items:\", mergedArray);\n\nreturn mergedArray.map(item => ({ json: item }));"
      },

    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\n// Example: Already processed shipment IDs\nconst alreadyRestockedShipments = [\n  \"TRACK12345\",\n  \"SHIP56789\",\n  \"XYZ999\"\n];\n\nconst orderList = [];\nconst restockedList = [];\n\nfunction generateShipmentID() {\n  // Generate a unique shipment ID (e.g., based on time)\n  const now = new Date();\n  const random = Math.floor(Math.random() * 1000);\n  return `SHIP-${now.getFullYear()}${(now.getMonth()+1)}${now.getDate()}-${random}`;\n}\n\nfor (const item of items) {\n  const data = item.json;\n\n  // Normalize fields (support different casing or naming)\n  const itemName = data[\"Item name\"] || data[\"ItemName\"] || data.ItemName || \"Unknown Item\";\n  const barcode = data.BarCode || data.Barcode || data[\"Barcode\"] || \"Unknown Barcode\";\n  const quantity = parseInt(data.Quantity || data[\"quantity\"] || 0, 10);\n  const timestamp = data.timestamp || data.Date || new Date().toISOString();\n\n  const shipmentId =\n    data[\"Shipment Tracking\"] ||\n    data[\"Shipment ID\"] ||\n    data[\"Tracking ID\"] ||\n    data[\"ShipmentID\"] ||\n    \"Unknown\";\n\n  if (quantity === 0) {\n    // Dead stock – generate a new shipment ID for the new order\n    const newShipmentId = generateShipmentID();\n\n    orderList.push({\n      ItemName: itemName,\n      BarCode: barcode,\n      quantityToOrder: 10,\n      shipmentTracking: newShipmentId,\n      timestamp: new Date().toISOString()\n    });\n  } else {\n    // Check if shipment has already been logged\n    if (!alreadyRestockedShipments.includes(shipmentId)) {\n      restockedList.push({\n        ItemName: itemName,\n        BarCode: barcode,\n        quantityInStock: quantity,\n        shipmentId: shipmentId,\n        timestamp: timestamp\n      });\n    }\n  }\n}\n\n// Final output array\nconst output = [];\n\n// Orders (new orders due to dead stock)\nfor (const order of orderList) {\n  output.push({\n    json: {\n      type: \"order\",\n      ...order\n    }\n  });\n}\n\n// Restocked items (new ones only)\nfor (const restocked of restockedList) {\n  output.push({\n    json: {\n      type: \"restocked\",\n      ...restocked\n    }\n  });\n}\n\nreturn output;"
      },

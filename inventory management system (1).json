    {
      "parameters": {
        "jsCode": "// Generate a UUID (v4-style)\nfunction generateUUID() {\n  return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {\n    const r = Math.random() * 16 | 0;\n    const v = c === 'x' ? r : (r & 0x3 | 0x8);\n    return v.toString(16);\n  });\n}\n\n// Input data (use input from previous node in production)\nconst items = [\n  { \"BarCode\": 2736265 },\n  { \"Item name\": \"Chicken Bread\", \"Quantity\": 168, \"BarCode\": 5594262 },\n  { \"Item name\": \"Rice(kg)\", \"Quantity\": 240, \"BarCode\": 1691947 },\n  { \"Item name\": \"Pasta\", \"Quantity\": 0, \"BarCode\": 9281228 },\n  { \"Item name\": \"Cereal\", \"Quantity\": 224, \"BarCode\": 7797685 }\n];\n\n// Use existing shipment ID if passed from previous node\nlet shipmentId = $json[\"shipmentId\"];\nif (!shipmentId) {\n  shipmentId = generateUUID();\n}\n\n// Get current Date and Time\nconst now = new Date();\nconst dateStr = now.toISOString().slice(0, 10); // YYYY-MM-DD\nconst timeStr = now.toTimeString().slice(0, 8); // HH:MM:SS\n\n// Build output items\nconst output = items.map(item => {\n  return {\n    json: {\n      \"Shipment ID\": shipmentId,\n      \"Item name\": item[\"Item name\"] ?? \"\",\n      \"Quantity\": item[\"Quantity\"] ?? 0,\n      \"BarCode\": item[\"BarCode\"] ?? \"\",\n      \"Date\": dateStr,\n      \"Time\": timeStr\n    }\n  };\n});\n\nreturn output;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [

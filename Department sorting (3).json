      "parameters": {
        "jsCode": "// 🧠 Works for both single-input and multi-input Code nodes\n\n// Use `items` when only one input is connected, or `$input.all()` when multiple are\nlet input;\n\ntry {\n  input = $input.all(); // For multi-input nodes\n  if (!input || !Array.isArray(input) || input.length === 0) {\n    input = items; // Fallback to normal single input\n  }\n} catch (error) {\n  input = items; // If $input is undefined, fallback safely\n}\n\nconst output = [];\n\nfor (const item of input) {\n  const data = item.json || {};\n\n  const department = data.department || \"Unknown\";\n  const peopleString = data.newPeople || \"\";\n  const people = peopleString\n    .split(\",\")\n    .map(p => p.trim())\n    .filter(Boolean);\n\n  const date = data.date || new Date().toISOString().split(\"T\")[0];\n\n  for (const person of people) {\n    output.push({\n      json: {\n        name: person,\n        department: department,\n        date: date,\n        welcomeNote: `Welcome to the ${department.charAt(0).toUpperCase() + department.slice(1)} team, ${person}! 🎉`\n      }\n    });\n  }\n}\n\nreturn output;"
      },

    {
      "parameters": {
        "jsCode": "// 🧠 Purpose:\n// Mark meetings as done if their date <= today\n// Remove completed from \"active\" list\n// Sort remaining by date and department\n// Output all meetings as flat records (no empty fields)\n\nconst today = new Date().toISOString().split('T')[0];\nconst completed = [];\nconst remaining = [];\n\n// Separate completed vs remaining\nfor (const item of items) {\n  const data = { ...item.json };\n  const meetingDate = new Date(data.date);\n\n  // Ensure all required fields exist\n  data.email = data.email || '';\n  data.name = data.name || '';\n  data.department = data.department || '';\n  data.date = data.date || '';\n  data.subject = data.subject || '';\n  data.status = data.status || '';\n\n  if (meetingDate <= new Date(today)) {\n    data.status = 'done';\n    completed.push(data);\n  } else {\n    data.status = 'pending';\n    remaining.push(data);\n  }\n}\n\n// Sort remaining (future) meetings\nremaining.sort((a, b) => {\n  const dateA = new Date(a.date);\n  const dateB = new Date(b.date);\n\n  if (dateA.getTime() === dateB.getTime()) {\n    return a.department.localeCompare(b.department);\n  }\n  return dateA - dateB;\n});\n\n// ✅ Combine both so no empty or undefined outputs\nconst allMeetings = [\n  ...completed.map((m) => ({\n    json: {\n      message: '✅ Completed meetings (marked as done)',\n      name: m.name,\n      email: m.email,\n      department: m.department,\n      date: m.date,\n      subject: m.subject,\n      status: m.status,\n    },\n  })),\n  ...remaining.map((m) => ({\n    json: {\n      message: '✅ Remaining meetings (sorted)',\n      name: m.name,\n      email: m.email,\n      department: m.department,\n      date: m.date,\n      subject: m.subject,\n      status: m.status,\n    },\n  })),\n];\n\n// Output all meetings as separate n8n items\nreturn allMeetings;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -80,
        384
      ],
      "id": "a746f028-3e36-4528-86c1-a4ccd83e730d",
      "name": "Meeting Status"
    },
    {
      "parameters": {
        "jsCode": "// Helper to generate dummy email\nfunction generateEmail(name, department) {\n  if (!name) name = \"unknown\";\n  if (!department) department = \"unknown\";\n  const cleanName = name.toLowerCase().replace(/[^a-z0-9]+/g, '.');\n  const cleanDept = department.toLowerCase().replace(/[^a-z0-9]+/g, '');\n  return `${cleanName}@${cleanDept}.example.com`;\n}\n\n// Ensure items exist\nconst inputItems = items || [];\n\nif (inputItems.length === 0) {\n  return []; // nothing to process\n}\n\n// Group by department\nconst grouped = {};\nfor (const item of inputItems) {\n  const data = item.json || {};\n  const dept = data.department || \"unknown\";\n  if (!grouped[dept]) grouped[dept] = [];\n  grouped[dept].push(data);\n}\n\n// Pick one random person per department\nconst selected = [];\nfor (const dept in grouped) {\n  const people = grouped[dept];\n  if (people.length === 0) continue;\n  const chosen = people[Math.floor(Math.random() * people.length)];\n  chosen.email = generateEmail(chosen.name, chosen.department);\n  selected.push(chosen);\n}\n\n// OPTIONAL: If you only want 5 people total, uncomment below\n// selected.length = 5;\n\n// Prepare output\nconst output = selected.map(person => ({\n  json: {\n    name: person.name || \"Unknown\",\n    department: person.department || \"Unknown\",\n    date: person.date || new Date().toISOString().split(\"T\")[0],\n    email: person.email,\n    welcomeNote: person.welcomeNote || `Welcome to the ${person.department || \"team\"}, ${person.name || \"there\"}! 🎉`,\n    subject: `Meeting Invite - ${person.department ? person.department.toUpperCase() : \"UNKNOWN\"}`,\n    message: `${person.welcomeNote || \"\"}\\n\\nLet's schedule a short meeting to connect and align.`\n  }\n}));\n\nreturn output;"
      },

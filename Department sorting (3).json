    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\n// Structures\nconst departmentMap = {};      // department -> Set of people\nconst departmentCEOs = {};     // department -> CEO name\n\n// Get current date and time\nconst now = new Date();\nconst isoTimestamp = now.toISOString();\nconst readableDate = isoTimestamp.split(\"T\")[0];\n\n// Helper: Add name to department’s list\nfunction addToDepartment(dept, name) {\n  if (!name || typeof name !== 'string') return;\n\n  const cleanDept = dept.trim().toLowerCase(); // normalize key\n  const cleanName = name.trim();\n\n  if (!departmentMap[cleanDept]) {\n    departmentMap[cleanDept] = new Set();\n  }\n\n  departmentMap[cleanDept].add(cleanName);\n}\n\n// Process each item\nfor (const item of items) {\n  const data = item.json;\n  const department = data[\"Department\"] || \"Unknown\";\n  const departmentKey = department.trim().toLowerCase();\n\n  // Track department CEO (first occurrence)\n  const ceoName = data[\"Department CEO Name\"];\n  if (ceoName && !departmentCEOs[departmentKey]) {\n    departmentCEOs[departmentKey] = ceoName.trim();\n  }\n\n  // Add company name\n  const companyName = data[\"Company Name\"] || data[\"Company\"] || data[\"Name\"];\n  if (companyName) {\n    addToDepartment(department, companyName);\n  }\n\n  // Extract people names\n  const possibleNames = [\n    data[\"CEO\"],\n    data[\"CO Founder\"],\n    data[\"Co-Founder\"],\n    data[\"Founder\"],\n    data[\"Contact Person\"],\n    data[\"Primary Contact\"],\n    data[\"email\"]\n  ];\n\n  for (const name of possibleNames) {\n    if (name && typeof name === 'string' && name.trim() !== '') {\n      const cleaned = name.includes('@') ? name.split('@')[0] : name;\n      addToDepartment(department, cleaned);\n    }\n  }\n}\n\n// Build output\nconst output = [];\n\nfor (const [deptKey, peopleSet] of Object.entries(departmentMap)) {\n  const peopleList = Array.from(peopleSet);\n  const ceoName = departmentCEOs[deptKey] || \"N/A\";\n\n  output.push({\n    json: {\n      department: deptKey,\n      newPeopleCount: peopleList.length,\n      newPeople: peopleList.join(\", \"),\n      departmentCEO: ceoName,\n      timestamp: isoTimestamp,\n      date: readableDate\n    }\n  });\n}\n\nreturn output;"
      },
